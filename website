  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0d0d0d;
      color: white;
    }

    header {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      background: url('https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4') center/cover;
    }

    header h1 {
      font-size: 4rem;
      letter-spacing: 4px;
    }

    section {
      padding: 60px 20px;
      max-width: 900px;
      margin: auto;
    }

    .gallery img {
      width: 100%;
      margin-bottom: 20px;
      border-radius: 10px;
    }

    footer {
